---
import BaseLayout from "../layouts/BaseLayout.astro";
import { homeCopy, images } from "../content/site";

const titleMatch = homeCopy.title.match(/^(.+?[.!?])\s+(.+)$/);
---

<BaseLayout>
  <section class="home-intro">
    <div class="home-intro-copy">
      <h1>
        {titleMatch ? <><span>{titleMatch[1]}</span>{titleMatch[2]}</> : homeCopy.title}
      </h1>
      <div class="home-intro-lead">
        <p>{homeCopy.subtitle}</p>
        {homeCopy.body.map((item) => <p>{item}</p>)}
      </div>
      <div class="home-cta-group">
        <a class="btn-outline" href={homeCopy.scheduleHref}>{homeCopy.scheduleCta}</a>
        <a class="btn-outline btn-offer" href={homeCopy.ofertaHref}>{homeCopy.ofertaCta}</a>
      </div>
    </div>
    <img class="home-intro-image" src={images.homeHero.src} alt="Práctica de yoga en Espai Adarsha" />
  </section>

  <section class="home-value">
    <img class="home-value-image" src={images.homePractice.src} alt="Práctica consciente en Espai Adarsha" />
    <div class="home-value-copy">
      <h2>{homeCopy.practiceTitle}</h2>
      {homeCopy.practiceBody.map((item) => <p>{item}</p>)}
      <a class="btn-outline" href="/yoga/">{homeCopy.approachCta}</a>
    </div>
  </section>

  <section class="practice-heading">
    <h2>{homeCopy.practiceHeading}</h2>
  </section>
  <section class="practice-cards">
    {homeCopy.practiceOptions.map((option) => (
      <article class="practice-card">
        <img src={option.image.src} alt={option.alt} />
        <div class="practice-card-content">
          <h3>{option.title}</h3>
          <p>{option.body}</p>
          <a class="btn-outline" href={option.href}>{option.cta}</a>
        </div>
      </article>
    ))}
  </section>

  <section class="ecosystem-band">
    <img src={images.homeEcosystem.src} alt="Movimiento y conciencia pélvica" />
    <div class="ecosystem-copy">
      <h2>{homeCopy.ecosystemTitle}</h2>
      <p>{homeCopy.ecosystemBody}</p>
      <p>{homeCopy.ecosystemFoot}</p>
      <a class="btn-outline" href="/colaboradores/">{homeCopy.ecosystemCta}</a>
    </div>
  </section>
</BaseLayout>
