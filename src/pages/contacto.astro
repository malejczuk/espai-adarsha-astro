---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import { contact, images } from "../content/site";
---

<BaseLayout title="Espai Adarsha | Barcelona">
  <section class="section">
    <div class="container contact-layout">
      <div class="stack">
        <img class="feature-image" src={images.studioWide.src} alt="Sala principal de Espai Adarsha" width={images.studioWide.width} height={images.studioWide.height} />
        <h1 class="display">Contacto</h1>
        <h2>Dirección</h2>
        <p>Calle Girona 166<br />Entresuelo 3a<br />08037 Barcelona</p>
        <h2>Contacto</h2>
        <p>Ponte en contacto con nosotros enviándonos un mail :-)</p>
        <p><a href={`mailto:${contact.email}`}>{contact.email}</a></p>
        <p>Instagram: <a href="https://www.instagram.com/espaiadarsha/">@espaiadarsha</a></p>
      </div>
      <ContactForm subject="Contacto desde espaiadarsha.com" />
    </div>
  </section>
</BaseLayout>
