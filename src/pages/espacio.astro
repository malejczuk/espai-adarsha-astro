---
import BaseLayout from "../layouts/BaseLayout.astro";
import { contact, espacioCopy, images } from "../content/site";
---

<BaseLayout title="Alquiler de Sala de Yoga en Gràcia - Eixample | Espai Adarsha">
  <img class="space-hero" src={images.studioWide.src} alt="Espai Adarsha" />
  <section class="space-main">
    <div class="container">
      <div class="space-pair">
        <img src={images.studioShelf.src} alt="Material de yoga en Espai Adarsha" />
        <img src={images.studioWindow.src} alt="Luz natural en Espai Adarsha" />
      </div>
      <div class="space-copy">
        {espacioCopy.body.map((item) => <p>{item}</p>)}
        <ul>{espacioCopy.uses.map((item) => <li>{item}</li>)}</ul>
        <p class="email">Escríbenos en <a href={`mailto:${contact.email}?subject=Alquiler sala`}>{contact.email}</a> para recibir más información.</p>
      </div>
      <img class="space-wide" src={images.studioEmpty.src} alt="Sala de Espai Adarsha disponible para alquiler" />
    </div>
  </section>
  <section class="space-details">
    <div class="container space-details-inner">
      <img src={images.studioDetail.src} alt="Detalle del estudio" />
      <div>
        <h2>Dirección</h2><p>Calle Girona 166, entresuelo 3<br />Barcelona</p>
        <h2>Contacto</h2><p><a href={`mailto:${contact.email}`}>{contact.email}</a></p>
        <h2>Visitas espacio</h2>{espacioCopy.visits.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>
</BaseLayout>
