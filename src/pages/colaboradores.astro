---
import BaseLayout from "../layouts/BaseLayout.astro";
import { colaboradoresCopy, images } from "../content/site";
---

<BaseLayout title={colaboradoresCopy.pageTitle}>
  <section class="page-title-band">
    <h1>{colaboradoresCopy.title}</h1>
    <p>{colaboradoresCopy.subtitle}</p>
  </section>
  <section class="editorial-grid collab-main">
    <div class="editorial-copy">
      <h2>{colaboradoresCopy.activity}</h2>
      <p class="collab-subtitle">{colaboradoresCopy.teacher}</p>
      <p class="collab-question">{colaboradoresCopy.question}</p>
      {colaboradoresCopy.body.map((item) => <p>{item}</p>)}
    </div>
    <img class="editorial-image" src={images.colaboradoresMain.src} alt="Sesión de movimiento y conciencia pélvica" />
  </section>
  <section class="collab-prices">
    <h2>{colaboradoresCopy.scheduleHeading}</h2>
    <p>{colaboradoresCopy.schedule}</p>
    <p>{colaboradoresCopy.booking.prefix} <a href={`mailto:${colaboradoresCopy.booking.email}`}>{colaboradoresCopy.booking.email}</a></p>
    <h3>{colaboradoresCopy.pricesHeading}</h3>
    {colaboradoresCopy.prices.map((item) => <p>- {item}</p>)}
  </section>
  <section class="collab-personal">
    <img src={images.colaboradoresPersonal.src} alt="Acompañamiento personalizado" />
    <div class="editorial-copy">
      <h2>{colaboradoresCopy.personalizedHeading}</h2>
      {colaboradoresCopy.personalized.map((item) => <p>{item}</p>)}
    </div>
  </section>
</BaseLayout>
