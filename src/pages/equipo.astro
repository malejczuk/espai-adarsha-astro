---
import BaseLayout from "../layouts/BaseLayout.astro";
import { equipoCopy } from "../content/site";
---

<BaseLayout title={equipoCopy.pageTitle}>
  <section class="meaning-band">
    <h1>{equipoCopy.name}</h1>
    <p class="sanskrit">{equipoCopy.sanskrit}</p>
    <p class="meaning">{equipoCopy.meaning.map((line) => <>{line}<br /></>)}</p>
  </section>
  <section class="team-section">
    <div class="container">
      <div class="team-intro">
        <h2>{equipoCopy.heading}</h2>
        <p>{equipoCopy.intro}</p>
      </div>
      <div class="team-grid">
        {equipoCopy.members.map((member) => (
          <article class="team-card">
            <a href={member.href}><img src={member.image.src} alt={member.name} /></a>
            <h3><a href={member.href}>{member.name}</a></h3>
            <p>{member.role}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
