---
import { images, navItems, siteMeta } from "../content/site";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isCurrent = (href: string) => {
  const path = href.replace(/\/$/, "") || "/";
  return currentPath === path;
};
---

<header>
  <a class="announcement-bar" href={siteMeta.announcement.href}>
    <span>{siteMeta.announcement.text}</span>
    <span aria-hidden="true">→</span>
  </a>
  <div class="site-header">
  <nav class="container nav" aria-label={siteMeta.navigationLabel}>
    <a class="brand" href="/" aria-label={siteMeta.homeLabel}>
      <img src={images.logo.src} alt={siteMeta.name} width={images.logo.width} height={images.logo.height} />
    </a>
    <div class="nav-links">
      {navItems.map((item) => (
        <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>{item.label}</a>
      ))}
    </div>
  </nav>
  </div>
</header>
